{
	"type": "array",
	"items": {
		"type": "object",
		"properties": {
			"description": {
				"type": "string"
			},
			"id": {
				"type": "string",
				"pattern": "^region:[a-z0-9][a-z0-9_]*$"
			},
			"label": {
				"type": "string"
			}
		},
		"required": ["id"],
		"additionalProperties": false
	},
	"$schema": "http://json-schema.org/draft-07/schema#"
}

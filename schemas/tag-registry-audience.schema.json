{
	"dialect": "draft-2020-12",
	"schema": {
		"type": "array",
		"items": {
			"type": "object",
			"properties": {
				"default_lang": {
					"type": "string",
					"allOf": [
						{
							"pattern": "^[a-z]{2}(-[A-Z]{2})?$"
						}
					]
				},
				"description": {
					"type": "string"
				},
				"id": {
					"type": "string",
					"allOf": [
						{
							"pattern": "^audience:[a-z0-9][a-z0-9_]*$"
						}
					]
				},
				"label": {
					"type": "string"
				}
			},
			"required": ["default_lang", "id", "label"],
			"additionalProperties": false
		}
	},
	"definitions": {}
}

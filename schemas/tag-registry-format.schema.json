{
	"type": "array",
	"items": {
		"type": "object",
		"properties": {
			"default_lang": {
				"type": "string",
				"pattern": "^[a-z]{2}(-[A-Z]{2})?$"
			},
			"description": {
				"type": "string"
			},
			"id": {
				"type": "string",
				"pattern": "^format:[a-z0-9][a-z0-9_]*$"
			},
			"label": {
				"type": "string"
			}
		},
		"required": ["default_lang", "id", "label"],
		"additionalProperties": false
	},
	"$schema": "http://json-schema.org/draft-07/schema#"
}

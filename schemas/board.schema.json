{
	"dialect": "draft-2020-12",
	"schema": {
		"type": "object",
		"properties": {
			"categories": {
				"type": "array",
				"items": {
					"type": "object",
					"properties": {
						"filter": {
							"type": "object",
							"properties": {
								"kinds": {
									"type": "array",
									"items": {
										"type": "string",
										"enum": ["text", "numeric", "order"]
									}
								},
								"limit": {
									"type": "integer",
									"allOf": [
										{
											"minimum": 1
										}
									]
								},
								"tags_all": {
									"type": "array",
									"items": {
										"type": "string",
										"allOf": [
											{
												"pattern": "^(subject|difficulty|audience|region|format|warning):[a-z0-9][a-z0-9_]*$"
											}
										]
									}
								},
								"tags_any": {
									"type": "array",
									"items": {
										"type": "string",
										"allOf": [
											{
												"pattern": "^(subject|difficulty|audience|region|format|warning):[a-z0-9][a-z0-9_]*$"
											}
										]
									}
								},
								"tags_none": {
									"type": "array",
									"items": {
										"type": "string",
										"allOf": [
											{
												"pattern": "^(subject|difficulty|audience|region|format|warning):[a-z0-9][a-z0-9_]*$"
											}
										]
									}
								},
								"variants_any": {
									"type": "array",
									"items": {
										"type": "string",
										"enum": ["multiple_choice", "true_false", "open", "numeric_input", "range"]
									}
								}
							},
							"additionalProperties": false
						},
						"name": {
							"type": "string"
						},
						"pack_ref": {
							"type": "string",
							"allOf": [
								{
									"pattern": "^pack_[a-z0-9][a-z0-9_]*$"
								}
							]
						},
						"question_ids": {
							"type": "object",
							"patternProperties": {
								"^[a-z0-9][a-z0-9_]*$": {
									"type": "string",
									"allOf": [
										{
											"pattern": "^q_[a-z0-9][a-z0-9_]*$"
										}
									]
								}
							}
						}
					},
					"required": ["name"],
					"additionalProperties": false
				},
				"allOf": [
					{
						"minItems": 2
					}
				]
			},
			"description": {
				"type": "string"
			},
			"difficulty_map": {
				"type": "object",
				"additionalProperties": {
					"type": "array",
					"items": {
						"type": "string",
						"allOf": [
							{
								"pattern": "^(subject|difficulty|audience|region|format|warning):[a-z0-9][a-z0-9_]*$"
							}
						]
					}
				}
			},
			"id": {
				"type": "string",
				"allOf": [
					{
						"pattern": "^board_[a-z0-9][a-z0-9_]*$"
					}
				]
			},
			"points": {
				"type": "array",
				"items": {
					"type": "integer",
					"allOf": [
						{
							"minimum": 1
						}
					]
				},
				"allOf": [
					{
						"minItems": 2
					}
				]
			},
			"title": {
				"type": "string"
			}
		},
		"required": ["categories", "id", "points", "title"],
		"additionalProperties": false
	},
	"definitions": {}
}

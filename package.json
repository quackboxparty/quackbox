{
	"name": "quackbox",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && effect-language-service patch",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:unix": "eslint . --format unix",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"gen:schemas": "node --experimental-strip-types scripts/gen-schemas.ts",
		"validate-data": "node --experimental-strip-types scripts/validate-data.ts"
	},
	"devDependencies": {
		"@effect/eslint-plugin": "^0.3.2",
		"@effect/language-service": "^0.86.2",
		"@effect/vitest": "4.0.0-beta.78",
		"@eslint/compat": "2.1.0",
		"@eslint/js": "10.0.1",
		"@inlang/paraglide-js": "2.18.1",
		"@playwright/test": "1.59.1",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "2.61.1",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@types/node": "24.12.4",
		"@vitest/browser-playwright": "4.1.8",
		"eslint": "10.4.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-formatter-unix": "9.0.1",
		"eslint-plugin-svelte": "3.19.0",
		"globals": "17.6.0",
		"playwright": "1.59.1",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.2",
		"svelte": "5.56.0",
		"svelte-check": "4.5.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.0",
		"vite": "8.0.16",
		"vitest": "4.1.8",
		"vitest-browser-svelte": "2.1.1"
	},
	"dependencies": {
		"@effect/platform-node": "4.0.0-beta.78",
		"@fontsource/caveat": "5.2.8",
		"@fontsource/cinzel-decorative": "5.2.8",
		"@fontsource/crimson-text": "5.2.7",
		"@fontsource/inter": "5.2.8",
		"@fontsource/jetbrains-mono": "5.2.8",
		"@fontsource/kalam": "5.2.8",
		"@fontsource/lora": "5.2.8",
		"@fontsource/medievalsharp": "5.2.8",
		"@fontsource/orbitron": "5.2.8",
		"@fontsource/press-start-2p": "5.2.7",
		"@fontsource/quicksand": "5.2.10",
		"@fontsource/rajdhani": "5.2.7",
		"@fontsource/rye": "5.2.7",
		"@fontsource/sancreek": "5.2.7",
		"bits-ui": "2.18.1",
		"effect": "4.0.0-beta.78",
		"yaml": "2.9.0"
	}
}
